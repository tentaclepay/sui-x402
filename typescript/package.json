{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@tentaclepay/sui-x402",
  "version": "2.1.6",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "keywords": [
    "x402",
    "payment",
    "protocol",
    "sui"
  ],
  "homepage": "https://github.com/tentaclepay/sui-x402#readme",
  "bugs": {
    "url": "https://github.com/tentaclepay/sui-x402/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tentaclepay/sui-x402.git"
  },
  "license": "Apache-2.0",
  "description": "x402 Payment Protocol Sui Implementation",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint-staged": "biome check . --write --staged --files-ignore-unknown=true --no-errors-on-unmatched"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.mts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./exact/client": {
      "import": {
        "types": "./dist/esm/exact/client/index.d.mts",
        "default": "./dist/esm/exact/client/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/exact/client/index.d.ts",
        "default": "./dist/cjs/exact/client/index.js"
      }
    },
    "./exact/server": {
      "import": {
        "types": "./dist/esm/exact/server/index.d.mts",
        "default": "./dist/esm/exact/server/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/exact/server/index.d.ts",
        "default": "./dist/cjs/exact/server/index.js"
      }
    },
    "./exact/facilitator": {
      "import": {
        "types": "./dist/esm/exact/facilitator/index.d.mts",
        "default": "./dist/esm/exact/facilitator/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/exact/facilitator/index.d.ts",
        "default": "./dist/cjs/exact/facilitator/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@mysten/sui": "2.17.0",
    "@total-typescript/ts-reset": "0.6.1",
    "@tsconfig/node22": "22.0.5",
    "@types/node": "25.9.1",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.7"
  },
  "dependencies": {
    "@x402/core": "2.12.0"
  },
  "peerDependencies": {
    "@mysten/sui": "^2.17.0"
  }
}
